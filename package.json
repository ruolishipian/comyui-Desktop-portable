{
  "name": "comfyui-portable-desktop",
  "version": "2.0.5",
  "description": "ComfyUI 便携桌面版 - TypeScript 模块化架构",
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "build:watch": "tsc --watch",
    "copy-assets": "node -e \"const fs=require('fs');const path=require('path');const src='assets';const dest='dist/assets';if(!fs.existsSync(dest))fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).forEach(f=>{const s=path.join(src,f);const d=path.join(dest,f);if(fs.statSync(s).isDirectory()){fs.cpSync(s,d,{recursive:true})}else{fs.copyFileSync(s,d)}})\"",
    "start": "npm run build && node start.js",
    "start:dev": "npm run build && node start.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:test",
    "check-duplicates": "jscpd src/",
    "check-all": "npm run lint && npm run typecheck:all && npm run check-duplicates",
    "format": "prettier --write \"**/*.{js,ts,html,css,json}\"",
    "quality-check": "node dist/scripts/quality-check.js",
    "prepackage": "npm run build && npm run typecheck:all && npm run quality-check",
    "package": "electron-packager . ComfyUI-Desktop --platform=win32 --arch=x64 --out=../ --overwrite --icon=assets/icon.ico --asar --prune=true",
    "build:win": "npm run build && electron-builder --win --config",
    "build:win:installer": "npm run build && electron-builder --win nsis --config",
    "build:win:portable": "npm run build && electron-builder --win zip --config",
    "build:win:all": "npm run build && electron-builder --win --config",
    "verify:icon": "node scripts/verify-icon-embedding.js",
    "test": "npm run test:unit",
    "test:unit": "npm run test:unit:main && npm run test:unit:renderer",
    "test:unit:main": "jest --config test/jest.config.js",
    "test:unit:renderer": "jest --config test/jest.renderer.config.js",
    "test:integration": "jest --config test/jest.integration.config.js",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:e2e": "playwright test --config test/playwright.config.js",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:coverage": "jest --coverage --coverageReporters=text-lcov --setupFilesAfterEnv=<rootDir>/test/setup.ts | coveralls",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:quick": "jest --config test/jest.config.js --onlyChanged --setupFilesAfterEnv=<rootDir>/test/setup.ts",
    "test:parallel": "jest --config test/jest.config.js --maxWorkers=4 --setupFilesAfterEnv=<rootDir>/test/setup.ts",
    "check:test-quality": "node scripts/check-test-quality.js",
    "check:all": "npm run check-all && npm run check:test-quality",
    "backup": "node auto-backup.js",
    "backup:start": "node auto-backup-schedule.js"
  },
  "keywords": [
    "comfyui",
    "stable-diffusion",
    "ai",
    "image-generation",
    "portable",
    "typescript",
    "electron"
  ],
  "author": "ComfyUI Community",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "tree-kill": "^1.2.2",
    "wait-on": "^7.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@types/wait-on": "^5.3.4",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "cross-env": "^10.1.0",
    "electron": "^31.3.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^8.56.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.32.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jscpd": "^4.0.8",
    "png-to-ico": "^3.0.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.2.4",
    "sharp": "^0.34.5",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "test/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  }
}
